{
    auto_https disable_redirects
    log default {
        output stdout
        format json
        level INFO
    }
}

:8443 {
    log {
        output stdout
        format json
    }
    tls /etc/certs/server.crt /etc/certs/server.key {
        client_auth {
            mode require_and_verify
            trust_pool file {
                pem_file /etc/certs/ca.crt
            }
        }
    }

    handle /* {
        reverse_proxy oauth2:8080
    }
}
